# Private/secret configurations
zsh/.zprivate

# Generated files
zsh/.zsh_sessions/
zsh/.zcompdump*
zsh/.zshrc.backup
zsh/.zsh_history
pyrightconfig.json

# Third-party tools (not portable)
act/
gcloud/
github-copilot/
nvm/
op/
iterm2/

# macOS
.DS_Store

# IDEs
.vscode/
.idea/

# Neovim lazy.nvim plugin directory
nvim/lazy-lock.json

# Atuin
atuin/key

# Password manager sensitive data
pwmanager/.env

# herdr — runtime state, captured pane output, logs, and vendored plugins
# (session captures can contain secrets; plugins/github is reinstallable from plugins.json)
herdr/session.json
herdr/session-history.json
herdr/*.log
herdr/plugins/github/
