emulate -L zsh
# Look up macOS-keychain secrets in parallel and export them. The parallel
# `security` reads run inside a FOREGROUND subshell, so the interactive parent
# shell gets NO job-control chatter ("[N] pid" / "[N] done") at startup: a
# subshell has no job control, and the parent never has a background job.
# All lookups use native `security` (fast); items stored by the `keyring` CLI are
# readable this way because keyring uses the macOS Keychain backend
# (`keyring get SERVICE ACCT` == `security -s SERVICE -a ACCT -w`).
# Spec lines on stdin (pipe-delimited):
#   sec|VAR|SERVICE            -> security -s SERVICE(-default system) -a VAR     -w   (account defaults to VAR)
#   sec|VAR|SERVICE|ACCOUNT    -> security -s SERVICE                  -a ACCOUNT -w   (account differs from VAR)
# Blank lines and lines starting with # are ignored.
local tmp; tmp=$(mktemp) || return 1
(
  local kind var a b acct
  while IFS='|' read -r kind var a b; do
    [[ -z "$kind" || "$kind" == \#* ]] && continue
    case "$kind" in
      sec) acct="${b:-$var}"
           { local v; v=$(security find-generic-password -s "${a:-system}" -a "$acct" -w 2>/dev/null);
             [[ -n $v ]] && print -r -- "export ${var}=${(q)v}" >> "$tmp"; } & ;;
    esac
  done
  wait
)
source "$tmp"
rm -f "$tmp"
