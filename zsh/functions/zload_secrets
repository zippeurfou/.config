emulate -L zsh
# Read pipe-delimited specs from stdin and export each, looking up secrets from
# the macOS login keychain in parallel and quietly (no job-control chatter).
# All lookups use native `security` (fast); `keyring` (Python) is avoided because
# it adds ~0.25s of interpreter startup per call. Spec lines:
#   sec|VAR|SERVICE            -> security -s SERVICE(-default system) -a VAR     -w   (account defaults to VAR)
#   sec|VAR|SERVICE|ACCOUNT    -> security -s SERVICE                  -a ACCOUNT -w   (account differs from VAR)
# Items stored by the `keyring` CLI are readable this way (keyring uses the
# macOS Keychain backend): `keyring get SERVICE ACCT` == `security -s SERVICE -a ACCT -w`.
# Blank lines and lines starting with # are ignored.
setopt local_options no_monitor no_notify
local tmp; tmp=$(mktemp) || return 1
local kind var a b acct
while IFS='|' read -r kind var a b; do
  [[ -z "$kind" || "$kind" == \#* ]] && continue
  case "$kind" in
    sec) acct="${b:-$var}"
         { local v; v=$(security find-generic-password -s "${a:-system}" -a "$acct" -w 2>/dev/null);
           [[ -n $v ]] && print -r -- "export ${var}=${(q)v}" >> "$tmp"; } & ;;
  esac
done
wait
source "$tmp"
rm -f "$tmp"
