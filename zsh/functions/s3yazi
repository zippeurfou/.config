emulate -L zsh
  local bucket="${1:?Usage: s3yazi bucket/path}"
  local mountpoint="/tmp/s3yazi_$$"
  mkdir -p "$mountpoint"

  eval $(aws configure export-credentials --profile data --format env)
  rclone nfsmount ":s3:${bucket}" "$mountpoint" \
    --s3-env-auth=true --s3-region=us-east-1 --s3-provider=AWS \
    --vfs-cache-mode full --dir-cache-time 30s --daemon

  sleep 2
  yazi "$mountpoint"

  umount "$mountpoint" 2>/dev/null
  rmdir "$mountpoint" 2>/dev/null
